PORT=3000

# Chave da Groq API (gratuita, sem cartão de crédito) usada para
# audiodescrição de imagens com Llama 3/4 Vision.
# Obtenha em https://console.groq.com/keys
# Sem essa chave, o upload de imagem do professor não funcionará.
GROQ_API_KEY=sua_chave

# Modelo multimodal a usar (opcional).
# Padrão: meta-llama/llama-4-scout-17b-16e-instruct
# Alternativas conhecidas:
#   meta-llama/llama-4-maverick-17b-128e-instruct  (maior, melhor qualidade)
#   meta-llama/llama-4-scout-17b-16e-instruct      (rápido, default)
# GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
